/** app.wxss **/
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
  background-color: #F5F5F5;
}

.container {
  padding: 20rpx;
  box-sizing: border-box;
}

/* 通用按钮样式 */
.btn-primary {
  background-color: #4A90E2;
  color: #fff;
  border-radius: 10rpx;
  padding: 20rpx 40rpx;
  text-align: center;
  font-size: 28rpx;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-secondary {
  background-color: #fff;
  color: #4A90E2;
  border: 2rpx solid #4A90E2;
  border-radius: 10rpx;
  padding: 20rpx 40rpx;
  text-align: center;
  font-size: 28rpx;
}

/* 通用卡片样式 */
.card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 标题样式 */
.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
}

/* 进度条 */
.progress-bar {
  width: 100%;
  height: 12rpx;
  background-color: #E5E5E5;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: #4A90E2;
  border-radius: 6rpx;
  transition: width 0.3s ease;
}
