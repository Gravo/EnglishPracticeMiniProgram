/** app.wxss **/
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
  background-color: #F5F5F5;
}

.container {
  padding: 20rpx;
  box-sizing: border-box;
}

/* 通用按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #4A90E2 0%, #357ABD 100%);
  color: #fff;
  border-radius: 50rpx;
  padding: 25rpx 50rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 15rpx rgba(74, 144, 226, 0.3);
}

.btn-primary:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-secondary {
  background-color: #fff;
  color: #4A90E2;
  border: 2rpx solid #4A90E2;
  border-radius: 50rpx;
  padding: 25rpx 50rpx;
  text-align: center;
  font-size: 30rpx;
}

.btn-danger {
  background: linear-gradient(135deg, #FF6B6B 0%, #EE5A5A 100%);
  color: #fff;
  border-radius: 50rpx;
  padding: 25rpx 50rpx;
  text-align: center;
  font-size: 30rpx;
}

/* 通用卡片样式 */
.card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

/* 标题样式 */
.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
}

/* 进度条 */
.progress-bar {
  width: 100%;
  height: 16rpx;
  background-color: #E8E8E8;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4A90E2 0%, #6BA3E0 100%);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-easy {
  background-color: #E8F5E9;
  color: #4CAF50;
}

.tag-medium {
  background-color: #FFF3E0;
  color: #FF9800;
}

.tag-hard {
  background-color: #FFEBEE;
  color: #F44336;
}

.tag-locked {
  background-color: #F5F5F5;
  color: #999;
}

/* 积分显示 */
.points-display {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  color: #fff;
  padding: 10rpx 25rpx;
  border-radius: 30rpx;
  font-weight: bold;
}

.points-display::before {
  content: '★';
  margin-right: 10rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  color: #999;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
}
