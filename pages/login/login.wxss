/* pages/login/login.wxss */

.login-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 32rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 欢迎卡片 */
.welcome-card {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 60rpx;
  text-align: center;
}

.welcome-title {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
}

.welcome-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 微信登录按钮 */
.wx-login-btn {
  width: 100%;
  height: 96rpx;
  background: #07C160;
  border: none;
  border-radius: 48rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.wx-login-btn::after {
  border: none;
}

.wx-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
}

/* 用户协议 */
.terms-section {
  text-align: center;
}

.terms-label {
  display: flex;
  align-items: center;
  justify-content: center;
}

.terms-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.link {
  color: #07C160;
}

/* 用户卡片 */
.user-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-bottom: 20rpx;
  border: 4rpx solid #07C160;
}

.nickname {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.welcome-tag {
  font-size: 24rpx;
  color: #07C160;
}

/* 激活卡片 */
.activate-card {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
}

.activate-title {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
  display: block;
  text-align: center;
  margin-bottom: 30rpx;
}

.activate-option {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.option-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.option-content {
  flex: 1;
}

.option-title {
  font-size: 30rpx;
  color: #fff;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.option-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.4);
}

.activate-option.demo {
  border: 2rpx dashed rgba(255, 200, 0, 0.5);
}

/* 成功卡片 */
.success-card {
  background: rgba(7, 193, 96, 0.2);
  border: 2rpx solid #07C160;
  border-radius: 24rpx;
  padding: 60rpx;
  text-align: center;
  margin-bottom: 60rpx;
}

.success-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.success-title {
  font-size: 40rpx;
  color: #07C160;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
}

.success-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 按钮样式 */
.logout-btn {
  width: 100%;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 44rpx;
  color: rgba(255, 255, 255, 0.8);
  font-size: 30rpx;
}

.start-btn {
  width: 100%;
  height: 96rpx;
  background: #07C160;
  border: none;
  border-radius: 48rpx;
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
}

/* 弹窗 */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.activate-dialog,
.terms-dialog {
  width: 600rpx;
  background: #1a1a2e;
  border-radius: 24rpx;
  padding: 40rpx;
}

.dialog-title {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
  display: block;
  text-align: center;
  margin-bottom: 40rpx;
}

.code-input {
  width: 100%;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 16rpx;
  padding: 0 30rpx;
  color: #fff;
  font-size: 32rpx;
  text-align: center;
  letter-spacing: 4rpx;
  box-sizing: border-box;
}

.error-text {
  font-size: 24rpx;
  color: #ff4d4f;
  display: block;
  text-align: center;
  margin-top: 20rpx;
}

.dialog-btns {
  display: flex;
  margin-top: 40rpx;
}

.dialog-cancel,
.dialog-confirm {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  margin: 0 10rpx;
}

.dialog-cancel {
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.8);
}

.dialog-confirm {
  background: #07C160;
  color: #fff;
}

.demo-hint {
  text-align: center;
  margin-top: 30rpx;
}

.demo-hint text {
  font-size: 22rpx;
  color: rgba(255, 200, 0, 0.8);
}

.terms-content {
  height: 400rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 30rpx;
  box-sizing: border-box;
}

.terms-content text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.8;
}

.terms-confirm {
  width: 100%;
  height: 88rpx;
  background: #07C160;
  border: none;
  border-radius: 44rpx;
  color: #fff;
  font-size: 30rpx;
  margin-top: 30rpx;
}
