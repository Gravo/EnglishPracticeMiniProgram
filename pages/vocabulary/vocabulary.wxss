/* pages/vocabulary/vocabulary.wxss */

.container {
  padding: 20rpx;
}

.study-area {
  margin-bottom: 30rpx;
}

.word-card {
  min-height: 400rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background-color: #fff;
  border-radius: 16rpx;
}

.word-text {
  font-size: 56rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.phonetic {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.meaning {
  text-align: center;
  margin-top: 20rpx;
}

.part-of-speech {
  display: block;
  font-size: 28rpx;
  color: #4A90E2;
  margin-bottom: 10rpx;
}

.definition {
  display: block;
  font-size: 36rpx;
  color: #333;
  line-height: 1.6;
}

.tap-hint {
  font-size: 28rpx;
  color: #999;
  margin-top: 60rpx;
}

.action-buttons {
  display: flex;
  justify-content: space-around;
  margin-top: 40rpx;
}

.btn-fail, .btn-know {
  width: 200rpx;
  padding: 20rpx 0;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

.btn-fail {
  background-color: #FF6B6B;
  color: #fff;
}

.btn-know {
  background-color: #4CAF50;
  color: #fff;
}

.progress-section {
  margin-bottom: 30rpx;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.progress-bar {
  width: 100%;
  height: 12rpx;
  background-color: #E5E5E5;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: #4A90E2;
  transition: width 0.3s ease;
}

.word-book {
  margin-top: 20rpx;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.book-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.book-item {
  padding: 15rpx 30rpx;
  background-color: #F5F5F5;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
}

.book-item.active {
  background-color: #4A90E2;
  color: #fff;
}
