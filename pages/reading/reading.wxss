/* pages/reading/reading.wxss */

.container {
  padding: 20rpx;
}

.article-list {
  margin-bottom: 20rpx;
}

.article-item {
  padding: 0;
  overflow: hidden;
  margin-bottom: 30rpx;
}

.article-cover {
  width: 100%;
  height: 300rpx;
  background-color: #F5F5F5;
}

.article-info {
  padding: 25rpx;
}

.article-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
  line-height: 1.4;
}

.article-summary {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.article-meta {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.category {
  font-size: 22rpx;
  color: #4A90E2;
  background-color: #EBF5FF;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
}

.words {
  font-size: 22rpx;
  color: #999;
}

.difficulty {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
}

.difficulty.easy {
  color: #4CAF50;
  background-color: #E8F5E9;
}

.difficulty.medium {
  color: #FF9800;
  background-color: #FFF3E0;
}

.difficulty.hard {
  color: #F44336;
  background-color: #FFEBEE;
}
