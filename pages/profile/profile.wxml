<!--pages/profile/profile.wxml-->
<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-header">
      <view class="avatar-placeholder">
        <text class="avatar-text">{{userInfo.nickName ? userInfo.nickName[0] : '学'}}</text>
      </view>
      <view class="user-info">
        <text class="nickname">{{userInfo.nickName || '英语学习者'}}</text>
        <view class="level-row">
          <view class="level-badge">Lv.{{userLevel}}</view>
          <view class="points-display">
            <text>★ {{totalPoints}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 连续打卡 -->
    <view class="streak-section">
      <view class="streak-icon">🔥</view>
      <view class="streak-info">
        <text class="streak-days">连续打卡 {{streakDays}} 天</text>
        <text class="streak-hint">坚持就是胜利！</text>
      </view>
    </view>
  </view>

  <!-- 学习统计 -->
  <view class="stats-card card">
    <view class="section-title">
      <text>学习统计</text>
    </view>
    <view class="stats-grid">
      <view class="stat-box">
        <text class="stat-num">{{completedLevels}}</text>
        <text class="stat-label">已完成关卡</text>
      </view>
      <view class="stat-box">
        <text class="stat-num">{{totalPlayCount}}</text>
        <text class="stat-label">总播放次数</text>
      </view>
      <view class="stat-box">
        <text class="stat-num">{{avgScore}}%</text>
        <text class="stat-label">平均准确率</text>
      </view>
      <view class="stat-box">
        <text class="stat-num">{{studyDays}}</text>
        <text class="stat-label">学习天数</text>
      </view>
    </view>
  </view>

  <!-- 成绩记录 -->
  <view class="records-card card">
    <view class="section-header">
      <text class="section-title">最近成绩</text>
      <text class="view-all" bindtap="viewAllRecords">查看全部 ></text>
    </view>
    <view class="records-list" wx:if="{{recentRecords.length > 0}}">
      <view class="record-item" wx:for="{{recentRecords}}" wx:key="index">
        <view class="record-info">
          <text class="record-title">{{item.levelTitle}}</text>
          <text class="record-date">{{item.date}}</text>
        </view>
        <view class="record-score">
          <text class="score">{{item.score}}分</text>
          <text class="accuracy">{{item.accuracy}}%</text>
        </view>
      </view>
    </view>
    <view class="empty-records" wx:if="{{recentRecords.length === 0}}">
      <text>还没有成绩记录，快去练习吧！</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-card card">
    <view class="menu-item" bindtap="goToSettings">
      <text class="menu-icon">⚙️</text>
      <text class="menu-text">设置</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="clearData">
      <text class="menu-icon">🗑️</text>
      <text class="menu-text">清除数据</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="about">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于</text>
      <text class="arrow">></text>
    </view>
  </view>
</view>
